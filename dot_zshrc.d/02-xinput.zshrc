# Trackpad
xinput set-prop "Synaptics TM3418-002" "libinput Tapping Enabled" 1
xinput set-prop "Synaptics TM3418-002" "libinput Natural Scrolling Enabled" 1
xinput set-prop "Synaptics TM3418-002" "libinput Disable While Typing Enabled" 0

# SteelSeries Mouse
xinput set-prop "SteelSeries SteelSeries Rival 100 Gaming Mouse" "libinput Natural Scrolling Enabled" 1
